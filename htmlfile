<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (window.lucide) lucide.createIcons();
  });

  function switchTab(el, tab, addLabel, addIcon) {
    document.querySelectorAll('.ptab-link').forEach(t => t.classList.remove('ptab-link-active'));
    el.classList.add('ptab-link-active');

    document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden'));
    document.getElementById('tab-' + tab).classList.remove('hidden');

    document.getElementById('primary-add-label').textContent = addLabel;
    const btn = document.getElementById('primary-add-btn');
    const icon = btn.querySelector('[data-lucide]');
    if (icon) icon.setAttribute('data-lucide', addIcon);
    if (window.lucide) lucide.createIcons();

    // WEWEB: also toggle btn visibility per tab role-gate:
    //   clients     → role in ['admin','manager']
    //   companies   → role in ['admin','manager']
    //   staff       → role = 'admin' only
    //   users       → role in ['admin','manager']
  }

  function openContact(id) { console.log('Open contact:', id); }
  function openCompany(id) { console.log('Open company:', id); }
  function openStaff(id)   { console.log('Open staff:', id); }
  function openUser(id)    { console.log('Open user:', id); }
  function pivotToCompany(id) {
    document.querySelector('[data-tab="companies"]').click();
    console.log('Filter companies to:', id);
  }

  // ======================================================
  // EXPORT (Admin only — see v-if on wrapper)
  //
  // WEWEB: replace stub with a workflow that:
  //   1. Reads the active tab id (data-tab on .ptab-link-active)
  //   2. Reads current filter chip + search input state
  //   3. Calls the matching Supabase RPC:
  //        export_clients(filter_json, format)
  //        export_companies(filter_json, format)
  //        export_staff(filter_json, format)
  //        export_portal_users(filter_json, format)
  //   4. RPC returns a signed download URL (xlsx generated server-side
  //      so ABN leading zeros and dates survive). CSV is generated
  //      from the same query result set.
  //   5. Trigger browser download of the signed URL.
  //
  // WEWEB: also log the export event to an audit table —
  //   user_id, tab, filter_json, format, row_count, timestamp.
  //   Required because exports are a data-exfiltration risk.
  // ======================================================
  function exportCurrentTab(format) {
    const activeTab = document.querySelector('.ptab-link-active')?.dataset.tab || 'clients';
    console.log('Export:', activeTab, 'as', format);
    closeExportMenu();
  }

  function toggleExportMenu(e) {
    e.stopPropagation();
    const menu = document.getElementById('export-menu');
    const btn = document.getElementById('export-menu-btn');
    const isOpen = !menu.classList.contains('hidden');
    if (isOpen) {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    } else {
      menu.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      if (window.lucide) lucide.createIcons();
    }
  }

  function closeExportMenu() {
    const menu = document.getElementById('export-menu');
    const btn = document.getElementById('export-menu-btn');
    if (menu) menu.classList.add('hidden');
    if (btn) btn.setAttribute('aria-expanded', 'false');
  }

  // Close menu on outside click or Escape
  document.addEventListener('click', (e) => {
    const wrapper = document.getElementById('export-wrapper');
    if (wrapper && !wrapper.contains(e.target)) closeExportMenu();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeExportMenu();
  });
</script>

